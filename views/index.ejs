<%- include('partials/header') %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-md-8">
      <form method="GET" action="/" class="input-group">
        <input type="text" class="form-control" placeholder="Wyszukaj zwierzę po imieniu..." name="search" value="<%= search %>">
        <button class="btn btn-outline-secondary" type="submit">🔍 Szukaj</button>
        <% if (search) { %>
          <a href="/" class="btn btn-outline-secondary">Wyczyść</a>
        <% } %>
      </form>
    </div>
    <div class="col-md-4 text-end">
      <a href="/add" class="btn btn-primary">+ Dodaj nowe zwierzę</a>
    </div>
  </div>

  <div class="row">
    <% if (animals && animals.length > 0) { %>
      <% animals.forEach(animal => { %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <% if (animal.image) { %>
              <img src="<%= animal.image %>" class="card-img-top" alt="<%= animal.name %>">
            <% } else { %>
              <div class="card-img-top placeholder-image">
                <div>🐾</div>
                <p>Brak zdjęcia</p>
              </div>
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= animal.name %></h5>
              <p class="card-text">
                <strong>Gatunek:</strong> <%= animal.species %><br>
                <strong>Płeć:</strong> <%= animal.gender || 'Nieznana' %><br>
                <strong>Wiek:</strong> <%= animal.age %> lat<br>
                <strong>Opis:</strong> <%= animal.description || 'Brak opisu' %>
              </p>
              <a href="/edit/<%= animal.id %>" class="btn btn-warning btn-sm">✏️ Edytuj</a>
              <form method="POST" action="/delete/<%= animal.id %>" style="display: inline;" onsubmit="return confirm('Na pewno chcesz usunąć <%= animal.name %>?')">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Usuń</button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-md-12">
        <p class="alert alert-info">Brak zwierząt w schronisku</p>
      </div>
    <% } %>
  </div>
</div>

  <footer style="background-color: #9a887c; color: white; border-top: 1px solid #dee2e6; margin-top: 50px; padding: 20px 0;">
    <div class="container text-center">
      <p class="mb-0">&copy; 2026 Schronisko dla zwierząt. Wszelkie prawa zastrzeżone.</p>
      <small>Opiekujemy się zwierzętami z miłością ❤️</small>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
