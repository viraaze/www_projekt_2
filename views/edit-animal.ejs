<%- include('partials/header') %>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-6 offset-md-3">
      <h2>Edytuj zwierzę</h2>
      <form method="POST" action="/edit/<%= animal.id %>" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="name" class="form-label">Imię:</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= animal.name %>" required>
        </div>
        <div class="mb-3">
          <label for="species" class="form-label">Gatunek:</label>
          <input type="text" class="form-control" id="species" name="species" value="<%= animal.species %>" required>
        </div>
        <div class="mb-3">
          <label for="age" class="form-label">Wiek (lata):</label>
          <input type="number" class="form-control" id="age" name="age" value="<%= animal.age %>">
        </div>
        <div class="mb-3">
          <label for="description" class="form-label">Opis:</label>
          <textarea class="form-control" id="description" name="description" rows="4"><%= animal.description || '' %></textarea>
        </div>
        <div class="mb-3">
          <label for="image" class="form-label">Zdjęcie:</label>
          <% if (animal.image) { %>
            <div class="mb-2">
              <img src="<%= animal.image %>" alt="<%= animal.name %>" style="max-width: 200px; max-height: 200px;">
            </div>
          <% } %>
          <input type="file" class="form-control" id="image" name="image" accept="image/*">
          <small class="form-text text-muted">Pozostaw puste, aby zachować obecne zdjęcie</small>
        </div>
        <button type="submit" class="btn btn-success">Zapisz zmiany</button>
        <a href="/" class="btn btn-secondary">Anuluj</a>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/footer') %>
